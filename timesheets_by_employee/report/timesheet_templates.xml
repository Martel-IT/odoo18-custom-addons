<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="timesheets_by_employee.report_timesheet_employee">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <!-- Bootstrap 5 (Odoo 18) defaults h2/h4/h5 and table padding much
                         larger than Bootstrap 4 (Odoo 16). Without overrides the same
                         timesheet that fit in 2 pages on v16 spreads to 4+ pages here,
                         and the submission footer block gets orphaned on its own page.
                         These rules clamp font sizes / spacing back to v16 density. -->
                    <style>
                        .o_ts_report h2 { font-size: 20px; margin-bottom: 12px; }
                        .o_ts_report h4 { font-size: 15px; margin-top: 12px; margin-bottom: 4px; padding: 6px 10px !important; }
                        .o_ts_report h5 { font-size: 13px; margin-top: 8px; margin-bottom: 4px; }
                        .o_ts_report p  { margin-bottom: 4px; }
                        .o_ts_report .row.mb-4 { margin-bottom: 6px !important; }
                        .o_ts_report .row.mt-4 { margin-top: 6px !important; }
                        .o_ts_report .row.mt-5 { margin-top: 14px !important; }
                        .o_ts_report .mt-3 { margin-top: 4px !important; }
                        .o_ts_report .mb-4 { margin-bottom: 6px !important; }
                        .o_ts_report table.table { font-size: 11px; margin-bottom: 6px; }
                        .o_ts_report table.table-sm &gt; :not(caption) &gt; * &gt; * { padding: 0.15rem 0.4rem; }
                        .o_ts_report .text-right { text-align: right; }
                    </style>
                    <div class="page o_ts_report">
                        <div class="container">
                            <!-- Report Title -->
                            <div class="row">
                                <div class="col-12 text-center mb-4">
                                    <h2>Timesheet Report by Employees</h2>
                                </div>
                            </div>

                            <!-- Employee and Period Info -->
                            <div class="row mb-4">
                                <div class="col-6">
                                    <strong>Employee Name: </strong>
                                    <span t-esc="employee.name"/>
                                </div>
                                <div class="col-6">
                                    <strong>Period: </strong>
                                    <span t-esc="period"/>
                                </div>
                            </div>

                            <!-- Total Hours -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <strong>Total Hours: </strong>
                                    <span t-esc="timesheet_data['total_hours_display']"/>
                                </div>
                            </div>

                            <!-- Projects Loop -->
                            <t t-foreach="timesheet_data['projects']" t-as="project">
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <h4 class="bg-light p-2" t-esc="project"/>

                                        <!-- Tasks with name -->
                                        <t t-foreach="timesheet_data['projects'][project]['tasks']" t-as="task">
                                            <t t-if="task != 'No Task'">
                                                <div class="mt-3">
                                                    <h5 t-esc="task"/>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-bordered">
                                                            <thead>
                                                                <tr>
                                                                    <th width="15%">Date</th>
                                                                    <th width="70%">Description</th>
                                                                    <th width="15%" class="text-right">Hours</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <t t-foreach="timesheet_data['projects'][project]['tasks'][task]['entries']" t-as="entry">
                                                                    <tr>
                                                                        <td><span t-esc="entry['date']" t-options="{'widget': 'date'}"/></td>
                                                                        <td><span t-esc="entry['description']"/></td>
                                                                        <td class="text-right"><span t-esc="entry['duration']"/></td>
                                                                    </tr>
                                                                </t>
                                                                <tr class="table-light">
                                                                    <td colspan="2" class="text-right"><strong>Task Total:</strong></td>
                                                                    <td class="text-right">
                                                                        <strong t-esc="timesheet_data['projects'][project]['tasks'][task]['subtotal_display']"/>
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </t>
                                        </t>

                                        <!-- Entries without task -->
                                        <t t-if="'No Task' in timesheet_data['projects'][project]['tasks']">
                                            <div class="mt-3">
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-bordered">
                                                        <thead>
                                                            <tr>
                                                                <th width="15%">Date</th>
                                                                <th width="70%">Description</th>
                                                                <th width="15%" class="text-right">Hours</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="timesheet_data['projects'][project]['tasks']['No Task']['entries']" t-as="entry">
                                                                <tr>
                                                                    <td><span t-esc="entry['date']" t-options="{'widget': 'date'}"/></td>
                                                                    <td><span t-esc="entry['description']"/></td>
                                                                    <td class="text-right"><span t-esc="entry['duration']"/></td>
                                                                </tr>
                                                            </t>
                                                            <tr class="table-light">
                                                                <td colspan="2" class="text-right"><strong>Total:</strong></td>
                                                                <td class="text-right">
                                                                    <strong t-esc="timesheet_data['projects'][project]['tasks']['No Task']['subtotal_display']"/>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </t>

                                        <div class="text-right mb-4 bg-light p-2">
                                            <strong>Project Total: </strong>
                                            <span t-esc="timesheet_data['projects'][project]['subtotal_display']"/>
                                        </div>
                                    </div>
                                </div>
                            </t>

                            <!-- Submission and Approval info. Wrapped in a no-break block
                                 so the Employee/Submitted/Reviewer/Approved lines never
                                 split across pages (was producing an orphan last page). -->
                            <div class="row mt-5 pt-4" style="border-top: 1px solid #dee2e6; page-break-inside: avoid;">
                                <div class="col-6">
                                    <p><strong>Employee:</strong> <span t-esc="employee.name"/></p>
                                    <p t-if="timesheet_submitted_date">
                                        <strong>Submitted on:</strong>
                                        <span t-esc="timesheet_submitted_date" t-options="{'widget': 'datetime'}"/>
                                    </p>
                                </div>
                                <div class="col-6 text-right">
                                    <p t-if="reviewer_name">
                                        <strong>Reviewer:</strong>
                                        <span t-esc="reviewer_name"/>
                                    </p>
                                    <p t-if="timesheet_approved_date">
                                        <strong>Approved on:</strong>
                                        <span t-esc="timesheet_approved_date" t-options="{'widget': 'datetime'}"/>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Custom footer: overrides external_layout's multi-line address
                         footer with the compact single-line Tel/Email/Web layout used
                         in the Odoo 16 version of the report. wkhtmltopdf renders any
                         element with class="footer" as the page footer. -->
                    <div class="footer">
                        <div class="text-center" style="border-top: 1px solid #dee2e6; padding-top: 10px;">
                            <div class="row">
                                <div class="col-12 text-center">
                                    <span t-if="company_data.get('phone')">Tel: <t t-esc="company_data['phone']"/></span>
                                    <span t-if="company_data.get('email')" style="margin: 0 15px;">Email: <t t-esc="company_data['email']"/></span>
                                    <span t-if="company_data.get('website')">Web: <t t-esc="company_data['website']"/></span>
                                </div>
                            </div>
                            <div class="text-center text-muted mt-2">
                                Page <span class="page"/> of <span class="topage"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
