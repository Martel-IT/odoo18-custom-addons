<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Override web.external_layout_striped
        Martel Innovate – branded PDF report header/footer
        Primary: #284b55  |  Accent line: 3px solid teal
    -->
    <template id="external_layout_striped_martel"
              inherit_id="web.external_layout_striped"
              priority="20">

        <!-- ── Replace the entire header div ──────────────────────────────── -->
        <xpath expr="//div[hasclass('header')]" position="replace">
            <div t-attf-class="o_company_#{company.id}_layout header"
                 style="border-bottom: 3px solid #284b55; padding-bottom: 12px; margin-bottom: 4px;">

                <div class="d-flex align-items-center justify-content-between">

                    <!-- Left: logo -->
                    <div style="flex: 0 0 auto; max-width: 180px;">
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             alt="Logo"
                             style="max-height: 60px; width: auto; object-fit: contain;"/>
                    </div>

                    <!-- Right: company info -->
                    <div style="flex: 1 1 auto; text-align: right; font-size: 11px;
                                color: #444; line-height: 1.55;">

                        <div style="font-size: 13px; font-weight: 700; color: #284b55;">
                            <t t-esc="company.name"/>
                        </div>

                        <t t-if="not company.is_company_details_empty">
                            <span t-field="company.company_details"/>
                        </t>
                        <t t-else="">
                            <span t-field="company.partner_id"
                                  t-options="{&quot;widget&quot;: &quot;contact&quot;,
                                              &quot;fields&quot;: [&quot;address&quot;],
                                              &quot;no_marker&quot;: true}"/>
                        </t>

                        <t t-if="not forced_vat and company.vat">
                            <div>
                                <t t-esc="company.country_id.vat_label or 'Tax ID'"/>:
                                <span t-esc="company.vat"/>
                            </div>
                        </t>
                        <t t-elif="forced_vat">
                            <div>
                                <t t-esc="company.country_id.vat_label or 'Tax ID'"/>:
                                <span t-esc="forced_vat"/>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- ── Replace the footer ─────────────────────────────────────────── -->
        <xpath expr="//div[hasclass('footer')]" position="replace">
            <div t-attf-class="footer o_company_#{company.id}_layout {{report_type != 'pdf' and 'mt-auto'}}"
                 style="border-top: 2px solid #284b55; padding-top: 6px;">

                <div class="d-flex justify-content-between align-items-center"
                     style="font-size: 10px; color: #666;">

                    <div>
                        <t t-field="company.report_footer"/>
                    </div>

                    <div class="text-right" style="text-align: right; white-space: nowrap;">
                        <div t-if="report_type == 'pdf' and display_name_in_footer"
                             class="text-muted" t-out="o.name"/>
                        <div t-if="report_type == 'pdf'">
                            Page <span class="page"/> / <span class="topage"/>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

    </template>
</odoo>
