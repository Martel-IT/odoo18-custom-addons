<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Nascondi "Split Expense" button e campo "Included Taxes" dal form spese -->
    <record id="hr_expense_view_form_martel" model="ir.ui.view">
        <field name="name">hr.expense.form.martel</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <!-- Rimuovi il pulsante Split Expense -->
            <button name="action_split_wizard" position="replace"/>
            <!-- Rimuovi il campo Included Taxes (label + field + importo tax) -->
            <label for="tax_ids" position="replace"/>
            <field name="tax_ids" position="replace"/>
            <field name="tax_amount_currency" position="replace"/>
            <!-- Sostituisci analytic_distribution (multi-progetto) con un semplice Many2one
                 Operiamo sull'intero gruppo perché il campo ha groups="analytic.group_analytic_accounting"
                 e Odoo 18 lo strippa prima di applicare gli xpath diretti. -->
            <!-- Remove PDF attachment preview panel -->
            <xpath expr="//div[contains(@class,'o_attachment_preview')]" position="replace"/>
            <xpath expr="//group[field[@name='date']][field[@name='vendor_id']]" position="replace">
                <group>
                    <field name="date" readonly="not is_editable" class="w-50"/>
                    <field name="vendor_id" invisible="payment_mode != 'company_account'"/>
                    <field name="accounting_date"
                           invisible="not accounting_date or state not in ['approved', 'done']"
                           readonly="not is_editable"/>
                    <field name="account_id" options="{'no_create': True}"
                           domain="[('account_type', 'not in', ('asset_receivable','liability_payable','asset_cash','liability_credit_card')), ('deprecated', '=', False), ('company_ids', 'parent_of', company_id)]"
                           groups="account.group_account_readonly" readonly="not is_editable"
                           context="{'default_company_id': company_id}"/>
                    <!-- Placeholder invisibile: serve come ancora per altre view (es. sale_expense) -->
                    <field name="analytic_distribution" widget="analytic_distribution"
                           options="{'product_field': 'product_id', 'account_field': 'account_id', 'business_domain': 'expense'}"
                           readonly="not is_editable" invisible="1"/>
                    <field name="analytic_account_id"
                           domain="[('company_id', 'in', [company_id, False])]"
                           options="{'no_create': True}"/>
                    <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Expense sheet form: always show attachment button + count in the lines list -->
    <record id="hr_expense_sheet_view_form_martel" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form.martel</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <!-- Show nb_attachment count column -->
            <field name="nb_attachment" position="attributes">
                <attribute name="column_invisible">False</attribute>
                <attribute name="string">Attach.</attribute>
            </field>
            <!-- Always show the attachment button (even when 0) so users can add attachments -->
            <button name="action_get_attachment_view" position="attributes">
                <attribute name="invisible">False</attribute>
            </button>
        </field>
    </record>

    <!-- Override Expenses Analysis pivot: default measure = Total (company currency)
         instead of Total in Currency -->
    <record id="hr_expense_view_pivot_martel" model="ir.ui.view">
        <field name="name">hr.expense.pivot.martel</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_pivot"/>
        <field name="arch" type="xml">
            <field name="total_amount_currency" position="replace">
                <field name="total_amount" type="measure"/>
            </field>
        </field>
    </record>
</odoo>
